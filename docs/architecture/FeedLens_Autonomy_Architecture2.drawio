                    <mxGeometry x="60" y="908" width="1330" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="summary_label" value="总结：三层自主性 (v2 更新)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontStyle=1;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="80" y="916" width="250" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="summary_t1" value="1. 触发自主 — 系统按 cron 定时/手动触发醒来干活（被动→主动），Planner 阶段检测 Breaking News" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#1565C0;" parent="1" vertex="1">
                    <mxGeometry x="80" y="940" width="600" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="summary_t2" value="2. 决策自主 — 规则优先路由 (正常流程 100% 规则覆盖) + LLM 兜底，observe 评估质量，reflect 自主判断是否达标" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="80" y="960" width="620" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="summary_t3" value="3. 进化自主 — FeedbackAgent 异步 EMA 更新偏好向量 + SQLite 情节记忆 + ChromaDB 长期记忆，下轮自动变化" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#2E7D32;" parent="1" vertex="1">
                    <mxGeometry x="80" y="980" width="650" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="summary_t4" value="4. 安全兜底 — react_cycle&lt;3 + agentic_turn&lt;5 双重上限 + 死循环检测 + abort 自主中止 + run_with_isolation 子Agent隔离" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#C62828;" parent="1" vertex="1">
                    <mxGeometry x="80" y="1000" width="700" height="18" as="geometry"/>
                </mxCell>
                <mxCell id="vs_label" value="v1 → v2 主要变更" style="text;html=1;strokeColor=none;fillColor=#FFF3E0;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1;fontColor=#BF360C;rounded=1;strokeWidth=1;strokeColor=#E65100;" parent="1" vertex="1">
                    <mxGeometry x="830" y="915" width="150" height="19" as="geometry"/>
                </mxCell>
                <mxCell id="vs_content" value="① Breaking News → Planner 内置规则（非独立实时模块）&lt;br&gt;② Router → 规则优先路由 + LLM 兜底&lt;br&gt;③ 新增 observe_results 节点（结构化观察摘要）&lt;br&gt;④ coordinator_reflect 退回条件 → overall_pass=false，退回目标 → planner&lt;br&gt;⑤ 双重上限 (react_cycle&amp;lt;3 + agentic_turn&amp;lt;5) + 死循环检测&lt;br&gt;⑥ FeedbackAgent → 异步独立入口 (threading.Thread)&lt;br&gt;⑦ 补充 ChromaDB feed_items + SQLite 情节记忆" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#37474F;" parent="1" vertex="1">
                    <mxGeometry x="830" y="938" width="540" height="85" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
