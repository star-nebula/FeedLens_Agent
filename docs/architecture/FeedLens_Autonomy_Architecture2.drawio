                    </mxGeometry>
                </mxCell>
                <mxCell id="e_fb_feed" value="update_memory 写入条目向量" style="endArrow=block;html=1;strokeWidth=1.5;strokeColor=#43A047;dashed=1;endFill=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" parent="1" source="nd_prefs" target="nd_feed_items" edge="1">
